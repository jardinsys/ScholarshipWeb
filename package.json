    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "snowflake-id": "^1.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
