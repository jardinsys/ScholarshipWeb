{
  "name": "scholarshipweb",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "docker:up": "docker compose -f pipeline/docker-compose.yml up -d",
    "docker:down": "docker compose -f pipeline/docker-compose.yml down",
    "docker:logs": "docker compose -f pipeline/docker-compose.yml logs -f",
    "docker:rebuild": "docker compose -f pipeline/docker-compose.yml up -d --build",
    "dev:api": "nodemon service/api/server.js",
    "dev:web": "vite --root service/webapp",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "start:all": "npm run docker:up && concurrently \"npm run dev:api\" \"npm run dev:web\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jardinsys/ScholarshipWeb.git"
  },
